---
import Layout from "../../../layouts/Layout.astro";
import PDFViewer from "../../../components/PDFViewer.astro";
import fs from "node:fs";
import path from "node:path";

const { year } = Astro.params;

const formattedYear = year;

const pdfPath = `/neptune/pdfs/Neptune${year}.pdf`;

const expectedCoverFile = `Neptune${year}.png`;
const publicCoverPath = path.join(
    process.cwd(),
    "public",
    "neptune",
    "covers",
    expectedCoverFile,
);

let coverImageUrl: string | null = null;

if (fs.existsSync(publicCoverPath)) {
    coverImageUrl = `/neptune/covers/${expectedCoverFile}`;
} else {
    const fallbackCoverModules = await Astro.glob(
        "/src/assets/neptune/covers/*.png",
    );
    const fallbackCover = fallbackCoverModules.find((module) => {
        const fileName = module.default.src.split("/").pop() ?? "";
        return fileName.includes(year);
    });

    if (fallbackCover) {
        coverImageUrl = fallbackCover.default.src;
    }
}

export async function getStaticPaths() {
    const publicPdfsDir = path.join(process.cwd(), "public/neptune/pdfs");

    if (!fs.existsSync(publicPdfsDir)) {
        console.warn(`Directory not found: ${publicPdfsDir}`);
        return [];
    }

    const pdfFiles = fs
        .readdirSync(publicPdfsDir)
        .filter((file) => file.endsWith(".pdf"));

    return pdfFiles
        .map((fileName) => {
            const matches = fileName.match(/Neptune(\d{4}-\d{2})\.pdf/);
            if (!matches) return null;

            const year = matches[1];
            return { params: { year } };
        })
        .filter(Boolean);
}
---

<Layout title={`Neptune Magazine ${formattedYear} Edition`}>
    <div class="edition-container">
        <div class="edition-header">
            <h1>Neptune Magazine {formattedYear} Edition</h1>

            {
                coverImageUrl && (
                    <div class="edition-cover">
                        <img
                            src={coverImageUrl}
                            alt={`Neptune Magazine ${formattedYear} Cover`}
                            loading="lazy"
                        />
                    </div>
                )
            }

            <div class="edition-description">
                <p>
                    Browse through the Neptune Magazine {formattedYear} edition below
                    or{" "}
                    <a href={pdfPath} download={`Neptune-${formattedYear}.pdf`}>
                        download the PDF
                    </a>
                    .
                </p>
            </div>
        </div>

        <PDFViewer pdfPath={pdfPath} />

        <div class="back-link">
            <a href="/neptune">← Back to Neptune Magazine</a>
        </div>
    </div>
</Layout>

<style>
    .edition-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 20px;
    }

    .edition-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .edition-cover {
        max-width: 300px;
        margin: 20px auto;
    }

    .edition-cover img {
        width: 100%;
        height: auto;
        border-radius: 5px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .edition-description {
        margin: 20px 0;
    }

    .back-link {
        margin-top: 30px;
        text-align: center;
    }

    .back-link a {
        color: #333;
        text-decoration: none;
        font-weight: bold;
    }

    .back-link a:hover {
        text-decoration: underline;
    }
</style>
