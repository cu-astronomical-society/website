---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import cuasLogo from "../assets/logo/cuas_largeblack_on_white.svg";
import obsNight from "../assets/photos/obs_night.png";
import talksPhoto from "../assets/photos/talks_photo.jpg";
import northumberlandOutside from "../assets/photos/northumberland-outside.jpg";
import northumberlandInside from "../assets/photos/northumberland-inside.jpg";
import socialsPhoto from "../assets/photos/socials_photo.jpg";
import telescope from "../assets/photos/telescope.jpeg";
---

<Layout>
    <!-- intro -->
    <!-- Comment out the static logo to only use the Hype animation -->
    <Image src={cuasLogo} alt="CUAS Logo" class="block mx-auto w-8/10 p-10" />
    
    <!-- Use the Logo component with proper capitalization
    <div class="logo-container">
        <Logo />
    </div> -->
    
    <div class="flex flex-col sm:flex-row gap-4 mt-4 mb-8 justify-center">
        <a href="/membership" target="_blank" rel="noopener noreferrer" class="bg-black hover:bg-gray-800 text-white font-semibold py-2 px-4 rounded transition-colors duration-200 text-center no-underline">
            Join as Member
        </a>
        <a href="https://lists.cam.ac.uk/sympa/subscribe/soc-cuas" target="_blank" rel="noopener noreferrer" class="bg-black hover:bg-gray-800 text-white font-semibold py-2 px-4 rounded transition-colors duration-200 text-center no-underline">
            Join Mailing List
        </a>
        <a href="https://instagram.com/camastrosoc" target="_blank" rel="noopener noreferrer" aria-label="Visit our Instagram at @camastrosoc" class="bg-black hover:bg-gray-800 text-white font-semibold py-2 px-4 rounded transition-colors duration-200 text-center no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 16 16" fill="currentColor">
              <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
          </svg>
        </a>
        <a href="https://chat.whatsapp.com/Km9jnIRkJZeAqMbmEkJWEB" target="_blank" rel="noopener noreferrer" aria-label="Join our stargazing groupchat" class="bg-black hover:bg-gray-800 text-white font-semibold py-2 px-4 rounded transition-colors duration-200 text-center no-underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
            <path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
          </svg>
        </a>
    </div>
    
    <div class="flex flex-col md:flex-row">
        <!-- Text block, 60% width -->
        <div class="w-full md:w-1/2 p-4 max-w-full">
            <h2>Welcome to CUAS</h2>
            <p>Founded in 1942, the Cambridge University Astronomical Society brings together students and university members passionate about the cosmos. We offer regular talks from leading astronomers, observation nights with historic telescopes, equipment training, and social events throughout the academic year.</p>
            <p>Stay connected through our active <a href="https://instagram.com/camastrosoc" target="_blank" rel="noopener noreferrer">Instagram profile</a>, where we share upcoming events, member astrophotography, and society news. We also have a <a href="https://chat.whatsapp.com/Km9jnIRkJZeAqMbmEkJWEB" target="_blank" rel="noopener noreferrer">stargazing WhatsApp groupchat</a> - the perfect place to share what you've spotted in the sky or pick up tips and tricks from the community.</p>
            <p>
                Find out more <a href="/about">about us</a> and <a
                    href="/about/history">our history</a
                >.
            </p>
        </div>
        <!-- Image block, 40% width -->
        <div class="w-full md:w-1/2 p-4 max-w-full">
            <Image
                src={telescope}
                alt="Observing night"
                class="block mx-auto w-full"
            />
        </div>
    </div>

    <!-- events -->

    <h2>What we do</h2>
    <div class="flex flex-col md:flex-row">
        <div class="w-full md:w-2/5 p-4 order-2 md:order-1">
            <Image
                src={talksPhoto}
                alt="Talks photo"
                class="block mx-auto w-full"
            />
        </div>
        <div class="w-full md:w-3/5 p-4 order-1 md:order-2">
            <h3>Talks</h3>
            <p>
                We invite a variety of people working in astronomy to give talks
                to the society. The topics are taken from a wide range of areas,
                from pure astrophysics to the history of astronomy, observing,
                and much more. Talks are generally about an hour long, including
                questions to the speaker, and are followed by casual
                conversation over refreshments. Talks cost £2 or are free to
                members.
            </p>
            <a href="/talks">Find out more</a>
        </div>
    </div>
    <div class="flex flex-col md:flex-row">
        <div class="w-full md:w-3/5 p-4 order-1">
            <h3>Obs events</h3>
            <p>
                ObsNights (weather permitting) are held at the Institute of
                Astronomy and combine both tips on practical astronomy with
                observing at the telescopes.
            </p>
            <p>
                We also train people to use the telescopes in their own time
                through Obs demos.
            </p>
            <p>
                There is also lots of <a href="/obs/telescopes/"
                    >fantastic equipment available</a
                > for member use.
            </p>
            <a href="/obs">Find out more</a>
        </div>
        <div class="w-full md:w-2/5 order-2">
            <Image
                src={obsNight}
                alt="Observing night"
                class="block mx-auto w-full"
            />
        </div>
    </div>
    <div class="flex flex-col md:flex-row">
        <div class="w-full md:w-2/5 p-4 order-2 md:order-1">
            <Image
                src={socialsPhoto}
                alt="Socials photo"
                class="block mx-auto w-full"
            />
        </div>
        <div class="w-full md:w-3/5 p-4 order-1 md:order-2">
            <h3>Social events</h3>
            <p>
                The main social events are the Annual Dinner in Lent and the
                Garden Party in Easter. There is also a squash at the beginning
                of the academic year and quiz nights throughout the year.
                Depending on the level of interest, we organise pub meets and/or
                lunches.
            </p>
            <a href="/socials">Find out more</a>
        </div>
    </div>
    <h2></h2>
</Layout>

<style>
.logo-container {
    width: 100%;
    max-width: 800px;
    margin: 0 auto;
    padding: 20px 0;
}
</style>
