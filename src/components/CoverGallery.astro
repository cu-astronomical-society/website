---
import fs from "node:fs";
import path from "node:path";

const publicCoversDir = path.join(process.cwd(), "public", "neptune", "covers");

const publicCoverEntries = fs.existsSync(publicCoversDir)
    ? fs
          .readdirSync(publicCoversDir, { withFileTypes: true })
          .filter(
              (entry) =>
                  entry.isFile() && entry.name.toLowerCase().endsWith(".png"),
          )
          .map((entry) => {
              const match = entry.name.match(/Neptune(20\d{2})-(\d{2})\.png$/i);
              if (!match) {
                  return null;
              }

              const startYear = match[1];
              const endYear = match[2];
              const academicYear = `${startYear}-${endYear}`;

              return {
                  academicYear,
                  sortKey: `${startYear}${endYear}`,
                  imageUrl: `/neptune/covers/${entry.name}`,
                  pdfUrl: `/neptune/pdfs/Neptune${academicYear}.pdf`,
              };
          })
          .filter(Boolean)
    : [];

const fallbackCoverModules =
    publicCoverEntries.length === 0
        ? await Astro.glob("/src/assets/neptune/covers/*.png")
        : [];

const fallbackCoverEntries = fallbackCoverModules.map((module) => {
    const fileName = module.default.src.split("/").pop() ?? "";
    const match = fileName.match(/Neptune(20\d{2})-(\d{2})/i);

    if (!match) {
        return {
            academicYear: "Unknown Year",
            sortKey: "0",
            imageUrl: module.default.src,
            pdfUrl: "#",
        };
    }

    const startYear = match[1];
    const endYear = match[2];
    const academicYear = `${startYear}-${endYear}`;

    return {
        academicYear,
        sortKey: `${startYear}${endYear}`,
        imageUrl: module.default.src,
        pdfUrl: `/neptune/pdfs/Neptune${academicYear}.pdf`,
    };
});

const coverEntries = (
    publicCoverEntries.length > 0 ? publicCoverEntries : fallbackCoverEntries
).sort((a, b) => b.sortKey.localeCompare(a.sortKey));
---

<div class="cover-gallery">
    {
        coverEntries.map((cover) => (
            <a
                href={cover.pdfUrl}
                class="cover-link"
                target="_blank"
                rel="noopener noreferrer"
            >
                <div class="cover-item">
                    <img
                        src={cover.imageUrl}
                        alt={`Neptune Magazine ${cover.academicYear}`}
                        class="cover-image"
                        loading="lazy"
                    />
                    <div class="cover-year">{cover.academicYear}</div>
                </div>
            </a>
        ))
    }
</div>

<style>
    .cover-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        margin: 30px 0;
    }

    .cover-link {
        text-decoration: none;
        color: inherit;
    }

    .cover-item {
        transition: transform 0.3s ease;
        display: flex;
        flex-direction: column;
        align-items: center;
    }

    .cover-item:hover {
        transform: scale(1.05);
    }

    .cover-image {
        width: 100%;
        height: auto;
        border-radius: 5px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .cover-year {
        margin-top: 8px;
        font-weight: bold;
    }
</style>
